# =============================================================================
# AimSync .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
aimsync-venv/
build-venv/

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- Environment & secrets ---
.env
.env.*
!.env.example
**/.env.local
**/secrets.*
**/*_secret*
.vercel/

# --- Build & release ---
build/
dist/
release/
*.spec
*.manifest
*.pkg
*.exe
*.msi
*.zip

# Maintainer-only build entrypoints (tracked copies live under scripts/)
/build_app.py
/build_beta.py
/build_helper.py

# Root-level batch wrappers only (scripts/*.bat are tracked)
/*.bat

# --- Local runtime data ---
config.json
*.local.json
.beta-data/
.aimsync-data/
patterns/
saved_patterns/
Config/saved_patterns/
**/bin/models/
**/bin/configs/

# --- Logs ---
*.log

# --- Generated exports & scratch ---
AimSync_CLEAN_SOURCE.txt
temp_*.py
**/*_source.py
*.bak
**/*.bak
posts.md
*.ps1

# --- IDE & OS ---
.vscode/
.idea/
.cursor/
*.code-workspace
*.swp
*~
.DS_Store
Thumbs.db
Desktop.ini

# --- Local-only reference / removed trees ---
Aimmy-Makcu/
AI/HelperApp/
vendor-ai-reference/
build-helper/
PatternExtractor/
Menu/
Cloud/

# Local weapon / G Hub reference imports (shipped via private releases)
Recoil/games/*.py
Recoil/games/*.lua
!Recoil/games/.gitkeep

# =============================================================================
# Protected core — private release artifacts; not in public clones
# =============================================================================
Recoil/recoil.py
Makcu/makcu_manager.py
Makcu/software_manager.py
Server/cloud_manager.py
